{
  "name": "mech-prep-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "enrich": "node scripts/gemini_batch_enrich.js",
    "enrich:mech": "node scripts/gemini_batch_enrich.js --file public/data/mechEngQuestions.json",
    "enrich:quants": "node scripts/gemini_batch_enrich.js --file public/data/quantsQuestions.json",
    "enrich:logical": "node scripts/gemini_batch_enrich.js --file public/data/logicalReasoningQuestions.json",
    "enrich:flash35": "node scripts/gemini_batch_enrich.js --model gemini-3.5-flash",
    "enrich:flash25": "node scripts/gemini_batch_enrich.js --model gemini-2.5-flash",
    "enrich:flash3": "node scripts/gemini_batch_enrich.js --model gemini-3-flash",
    "enrich:flashlite": "node scripts/gemini_batch_enrich.js --model gemini-3.1-flash-lite",
    "enrich:gemma": "node scripts/gemini_batch_enrich.js --model gemma-4-31b-it"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "firebase": "^12.15.0",
    "html2canvas": "^1.4.1",
    "idb": "^8.0.3",
    "jspdf": "^4.2.1",
    "katex": "^0.18.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.9"
  }
}
